{
  "module_type": "combinational",
  "test_vectors": [
    {
      "id": "PIPE_TP001",
      "desc": "Normal instruction flow: issue valid instruction through pipeline",
      "inputs": {
        "setIssueValidI": true,
        "setIssuePcI": 2147483680,
        "setIssueOpcodeI": 51,
        "setIssueRdValidI": true,
        "setIssueRdI": 5
      },
      "expected": {
        "getLoadE1O": false,
        "getStoreE1O": false,
        "getMulE1O": false,
        "getBranchE1O": false,
        "getValidWbO": false,
        "getStallO": false,
        "getSquashE1E2O": false
      }
    },
    {
      "id": "PIPE_TP002",
      "desc": "LSU load instruction (opcode 0x03) through issue",
      "inputs": {
        "setIssueValidI": true,
        "setIssueLsuI": true,
        "setIssuePcI": 2147483684,
        "setIssueOpcodeI": 3,
        "setIssueRdValidI": true,
        "setIssueRdI": 6
      },
      "expected": {
        "getLoadE1O": false,
        "getStoreE1O": false,
        "getStallO": false
      }
    },
    {
      "id": "PIPE_TP003",
      "desc": "LSU store instruction (opcode 0x23) through issue",
      "inputs": {
        "setIssueValidI": true,
        "setIssueLsuI": true,
        "setIssuePcI": 2147483688,
        "setIssueOpcodeI": 35,
        "setIssueRdValidI": true,
        "setIssueRdI": 7
      },
      "expected": {
        "getLoadE1O": false,
        "getStoreE1O": false,
        "getStallO": false
      }
    },
    {
      "id": "PIPE_TP004",
      "desc": "Mul instruction through issue",
      "inputs": {
        "setIssueValidI": true,
        "setIssueMulI": true,
        "setIssuePcI": 2147483692,
        "setIssueOpcodeI": 51,
        "setIssueRdValidI": true,
        "setIssueRdI": 8
      },
      "expected": {
        "getMulE1O": false,
        "getStallO": false
      }
    },
    {
      "id": "PIPE_TP005",
      "desc": "Branch instruction not taken (branch flag but not taken)",
      "inputs": {
        "setIssueValidI": true,
        "setIssueBranchI": true,
        "setIssueBranchTakenI": false,
        "setIssuePcI": 2147483696,
        "setIssueOpcodeI": 99,
        "setIssueRdValidI": false
      },
      "expected": {
        "getBranchE1O": false,
        "getSquashE1E2O": false,
        "getStallO": false
      }
    },
    {
      "id": "PIPE_TP006",
      "desc": "Branch taken: branch flag set and taken, should squash E1->E2",
      "inputs": {
        "setIssueValidI": true,
        "setIssueBranchI": true,
        "setIssueBranchTakenI": true,
        "setIssueBranchTargetI": 2147483648,
        "setIssuePcI": 2147483696,
        "setIssueOpcodeI": 99
      },
      "expected": {
        "getSquashE1E2O": true,
        "getStallO": false
      }
    },
    {
      "id": "PIPE_TP007",
      "desc": "Issue stall asserted",
      "inputs": {
        "setIssueValidI": true,
        "setIssueStallI": true,
        "setIssuePcI": 2147483700,
        "setIssueOpcodeI": 19
      },
      "expected": {
        "getStallO": true
      }
    },
    {
      "id": "PIPE_TP008",
      "desc": "External squash input asserted",
      "inputs": {
        "setSquashE1E2I": true
      },
      "expected": {
        "getSquashE1E2O": true
      }
    },
    {
      "id": "PIPE_TP009",
      "desc": "Interrupt taken",
      "inputs": {
        "setTakeInterruptI": true,
        "setIssueValidI": true,
        "setIssuePcI": 2147483704,
        "setIssueOpcodeI": 51
      },
      "expected": {
        "getSquashE1E2O": true,
        "getStallO": false
      }
    },
    {
      "id": "PIPE_TP010",
      "desc": "CSR instruction in E1",
      "inputs": {
        "setIssueValidI": true,
        "setIssueCsrI": true,
        "setIssuePcI": 2147483708,
        "setIssueOpcodeI": 115,
        "setIssueRdValidI": true,
        "setIssueRdI": 10
      },
      "expected": {
        "getStallO": false
      }
    },
    {
      "id": "PIPE_TP011",
      "desc": "Writeback squash asserted",
      "inputs": {
        "setSquashWbI": true
      },
      "expected": {
        "getValidWbO": false
      }
    },
    {
      "id": "PIPE_TP012",
      "desc": "E2 load waiting for memory completion (stall condition)",
      "inputs": {
        "setMemCompleteI": false
      },
      "expected": {
        "getStallO": true
      }
    },
    {
      "id": "PIPE_TP013",
      "desc": "Memory completion with load result",
      "inputs": {
        "setMemCompleteI": true,
        "setMemResultE2I": 305419896,
        "setMemExceptionE2I": 0
      },
      "expected": {
        "getResultE2O": 0,
        "getResultWbO": 0
      }
    },
    {
      "id": "PIPE_TP014",
      "desc": "Divider result complete",
      "inputs": {
        "setDivCompleteI": true,
        "setDivResultI": 3
      },
      "expected": {
        "getResultE2O": 0,
        "getResultWbO": 0
      }
    },
    {
      "id": "PIPE_TP015",
      "desc": "CSR E1 result written to E2 pipeline",
      "inputs": {
        "setCsrResultWriteE1I": true,
        "setCsrResultValueE1I": 256,
        "setCsrResultWdataE1I": 0,
        "setCsrResultExceptionE1I": 0
      },
      "expected": {
        "getResultWbO": 0
      }
    }
  ]
}
